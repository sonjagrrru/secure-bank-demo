# ============================================
# BANKING APP - Environment Configuration
# ============================================

# ===== Database =====
DB_USER=banking_user
DB_PASSWORD=secure_password
DB_NAME=banking_db
DB_HOST=postgres
DB_PORT=5432

# ===== Flask Backend =====
FLASK_ENV=production
SECRET_KEY=your-secret-key-change-this-in-production
ENCRYPTION_KEY=your-encryption-key-change-this-in-production
PORT=5000

# ===== TLS/SSL =====
SSL_CERT_PATH=/etc/ssl/certs/banking.crt
SSL_KEY_PATH=/etc/ssl/private/banking.key

# ===== CORS =====
CORS_ORIGINS=localhost:3000
API_URL=http://localhost:5000

# ===== Docker Compose =====
COMPOSE_PROJECT_NAME=banking_app
